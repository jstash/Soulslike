[gd_scene load_steps=4 format=3 uid="uid://classselect"]

[ext_resource type="Script" path="res://scripts/class_select.gd" id="1_cs"]
[ext_resource type="Script" path="res://scripts/bg_draw.gd" id="2_bg"]
[ext_resource type="Script" path="res://scripts/class_preview.gd" id="3_prev"]

[node name="ClassSelect" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_cs")

[node name="Background" type="Node2D" parent="."]
script = ExtResource("2_bg")

[node name="PanelCenter" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -110.0
offset_top = -75.0
offset_right = 110.0
offset_bottom = 75.0

[node name="VBox" type="VBoxContainer" parent="PanelCenter"]
layout_mode = 2
theme_override_constants/separation = 5

[node name="Header" type="Label" parent="PanelCenter/VBox"]
layout_mode = 2
text = "CHOOSE YOUR CLASS"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.85, 0.75, 0.45, 1)

[node name="ClassName" type="Label" parent="PanelCenter/VBox"]
layout_mode = 2
text = "Knight"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 12
theme_override_colors/font_color = Color(1, 0.95, 0.7, 1)

[node name="PreviewArea" type="SubViewportContainer" parent="PanelCenter/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 60)
stretch = true

[node name="SubViewport" type="SubViewport" parent="PanelCenter/VBox/PreviewArea"]
size = Vector2i(220, 60)
render_target_update_mode = 4

[node name="PreviewNode" type="Node2D" parent="PanelCenter/VBox/PreviewArea/SubViewport"]
position = Vector2(110, 50)
script = ExtResource("3_prev")

[node name="Stats" type="Label" parent="PanelCenter/VBox"]
layout_mode = 2
text = "HP 100  STAMINA 100  SPEED 100"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 6
theme_override_colors/font_color = Color(0.7, 0.85, 0.7, 1)

[node name="Desc" type="Label" parent="PanelCenter/VBox"]
layout_mode = 2
text = "Description"
horizontal_alignment = 1
autowrap_mode = 3
theme_override_font_sizes/font_size = 6
theme_override_colors/font_color = Color(0.8, 0.8, 0.85, 0.9)

[node name="Nav" type="HBoxContainer" parent="PanelCenter/VBox"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 20

[node name="LeftBtn" type="Button" parent="PanelCenter/VBox/Nav"]
layout_mode = 2
custom_minimum_size = Vector2(30, 0)
text = "< "
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.8, 0.75, 0.5, 1)

[node name="RightBtn" type="Button" parent="PanelCenter/VBox/Nav"]
layout_mode = 2
custom_minimum_size = Vector2(30, 0)
text = " >"
theme_override_font_sizes/font_size = 10
theme_override_colors/font_color = Color(0.8, 0.75, 0.5, 1)

[node name="ConfirmBtn" type="Button" parent="PanelCenter/VBox"]
layout_mode = 2
text = "EMBARK"
theme_override_font_sizes/font_size = 9
theme_override_colors/font_color = Color(0.85, 0.75, 0.45, 1)
theme_override_colors/font_hover_color = Color(1, 0.9, 0.5, 1)
theme_override_colors/font_focus_color = Color(1, 0.9, 0.5, 1)
